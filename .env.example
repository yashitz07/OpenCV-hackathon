# Environment variables for Manufacturing QC Environment

# ============================================================================
# Required for Inference
# ============================================================================

# Hugging Face API Token
HF_TOKEN=your_huggingface_token_here

# API Base URL for LLM calls
API_BASE_URL=https://router.huggingface.co/v1

# Model name to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ============================================================================
# Optional Configuration
# ============================================================================

# Task to run (basic_inspection, optimized_throughput, or adaptive_control)
MANUFACTURING_QC_TASK=basic_inspection

# Docker image name (if using Docker)
IMAGE_NAME=manufacturing-qc-env

# API Key (alternative to HF_TOKEN)
# API_KEY=your_api_key_here

# ============================================================================
# Deployment Configuration
# ============================================================================

# Port for the server (default: 7860)
PORT=7860
